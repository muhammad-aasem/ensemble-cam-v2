# Environment Variables for Ensemble CAM Project
# Copy this file to .env and replace the placeholder values with your actual tokens

# Hugging Face Hub Token
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_HUB_TOKEN=your_huggingface_token_here

# GitHub Personal Access Token (optional, for GitHub operations)
# Get your token from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Project Configuration
PROJECT_ROOT=/Users/macbook/dev/ensemble-cam
DATASET_DIR=dataset/NIH-Chest-X-ray
MODELS_DIR=models
